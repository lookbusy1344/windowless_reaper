{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"read": "allow",
		"edit": "allow",
		"bash": {
			"*": "allow",

			"git push*": "deny",
			"git reset --hard*": "deny",
			"git clean -f*": "deny",
			"git restore *": "ask",
			"git add -A*": "deny",
			"git add .": "deny",
			"*--no-verify*": "deny",

			"sudo *": "deny",
			"rm -rf *": "deny",
			"rm -r *": "deny",
			"find * -delete*": "deny",
			"find * -exec*": "deny",

			"cat /Users/*/.ssh/*": "deny",
			"cat /Users/*/.aws/*": "deny",
			"cat *.env": "deny",
			"cat /Users/*/.claude*": "deny",

			"swift package edit*": "ask",
			"swift package unedit*": "ask",
			"swift package reset": "ask",
			"swift package update*": "ask",
			"swift run*": "ask",

			"go install*": "deny",
			"cargo install*": "deny",
			"cargo publish*": "deny",
			"cargo yank*": "deny",
			"cargo login*": "deny",
			"rustup update*": "deny",
			"rustup default *": "deny",
			"rustup toolchain *": "deny",
			"rustup self *": "deny",
			"dotnet tool install*": "deny",
			"dotnet tool update*": "deny",
			"dotnet tool uninstall*": "deny",
			"dotnet nuget push*": "deny",
			"dotnet workload *": "deny",

			"brew install*": "deny",
			"brew uninstall*": "deny",
			"brew upgrade*": "deny",
			"npm install -g*": "deny",
			"npm i -g*": "deny",
			"npm install --global*": "deny",
			"npm publish*": "deny",
			"npm adduser*": "deny",
			"npm login*": "deny",
			"npm token *": "deny",
			"pnpm add -g*": "deny",
			"pnpm add --global*": "deny",
			"pnpm install -g*": "deny",
			"pnpm publish*": "deny",
			"pnpm setup*": "deny",
			"yarn global add*": "deny",
			"yarn publish*": "deny",
			"corepack enable*": "deny",
			"corepack prepare*": "deny",
			"npx --yes*": "ask",
			"pnpm dlx*": "ask",

			"pip install*": "deny",
			"pip3 install*": "deny",
			"pipx install*": "deny",
			"pipx upgrade*": "deny",
			"pipx inject*": "deny",
			"uv tool install*": "deny",
			"uv tool upgrade*": "deny",
			"uv pip install --system*": "deny",
			"uv python install*": "deny",
			"poetry self *": "deny",
			"poetry publish*": "deny",
			"twine upload*": "deny",
			"pyenv install*": "deny",

			"gh auth*": "ask",
			"gh pr create*": "ask",
			"gh pr merge*": "deny",
			"gh repo delete*": "deny"
		}
	}
}
